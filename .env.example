# RepoBrain environment template
#
# How to use:
# 1. Copy this file to `.env`.
# 2. Fill only the providers you explicitly enable in `repobrain.toml`.
# 3. Keep `.env` private. It is ignored by git.
#
# PowerShell:
#   Copy-Item .env.example .env
#
# Bash:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Local-first default
# ---------------------------------------------------------------------------
# RepoBrain does not need any API key when `repobrain.toml` uses:
#
# [providers]
# embedding = "local"
# reranker = "local"

# ---------------------------------------------------------------------------
# Gemini setup
# ---------------------------------------------------------------------------
# RepoBrain passes the Gemini rerank model string directly to the SDK.
# Valid choices depend on the Gemini API models currently available to you.
# Common text-model examples:
#   - gemini-2.5-flash
#   - gemini-2.5-flash-lite
#   - gemini-3.1-flash-lite-preview
#   - gemini-3-flash-preview
#   - gemini-2.5-flash-preview-09-2025
#
# Install SDK extras:
#   python -m pip install -e ".[providers]"
#
# Then set `repobrain.toml`:
#
# [providers]
# embedding = "gemini"
# reranker = "gemini"
# gemini_embedding_model = "gemini-embedding-001"
# gemini_output_dimensionality = 768
# gemini_task_type = "SEMANTIC_SIMILARITY"
# gemini_rerank_model = "gemini-2.5-flash"

GEMINI_API_KEY=
REPOBRAIN_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
REPOBRAIN_GEMINI_OUTPUT_DIMENSIONALITY=768
REPOBRAIN_GEMINI_TASK_TYPE=SEMANTIC_SIMILARITY
REPOBRAIN_GEMINI_RERANK_MODEL=gemini-2.5-flash
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3.1-flash-lite-preview,gemini-3-flash-preview

# If GEMINI_MODELS is set, RepoBrain will use this ordered pool for Gemini
# reranking and fail over to the next model when the current one hits
# quota or rate-limit exhaustion.

# Other valid examples:
# REPOBRAIN_GEMINI_RERANK_MODEL=gemini-3-flash-preview
# REPOBRAIN_GEMINI_RERANK_MODEL=gemini-2.5-flash-preview-09-2025

# ---------------------------------------------------------------------------
# Other optional providers
# ---------------------------------------------------------------------------
# Only fill these if you explicitly select the matching provider in
# `repobrain.toml`.

OPENAI_API_KEY=
REPOBRAIN_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

VOYAGE_API_KEY=
REPOBRAIN_VOYAGE_EMBEDDING_MODEL=voyage-code-3
REPOBRAIN_VOYAGE_INPUT_TYPE=document

COHERE_API_KEY=
REPOBRAIN_COHERE_RERANK_MODEL=rerank-v3.5
