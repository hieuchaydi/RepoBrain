{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repobrain.local/agoragentic/v1/request.schema.json",
  "title": "RepoBrain Agoragentic Retrieval Request",
  "type": "object",
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string"
    },
    "repo_scope": {
      "type": "string"
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "default": 8
    },
    "include_snippets": {
      "type": "boolean",
      "default": true
    }
  }
}

