{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repobrain.local/agoragentic/v1/request.schema.json",
  "title": "RepoBrain Agoragentic Retrieval Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Natural-language retrieval query."
    },
    "repo_scope": {
      "type": "string",
      "minLength": 1,
      "description": "Optional repo/workspace identifier or absolute path."
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 8,
      "description": "Maximum number of ranked results."
    },
    "include_snippets": {
      "type": "boolean",
      "default": true,
      "description": "Include matched excerpts in each result."
    }
  }
}

