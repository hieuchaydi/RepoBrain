{
  "name": "repobrain.retrieve_context",
  "description": "Retrieve ranked repository or workspace context from a local RepoBrain runtime.",
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string"
      },
      "repo_scope": {
        "type": "string"
      },
      "top_k": {
        "type": "integer",
        "minimum": 1,
        "default": 8
      },
      "include_snippets": {
        "type": "boolean",
        "default": true
      }
    },
    "required": ["query"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "results": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["path", "score", "source"],
          "properties": {
            "path": {
              "type": "string"
            },
            "score": {
              "type": "number"
            },
            "source": {
              "type": "string"
            },
            "confidence": {
              "type": "number"
            },
            "snippet": {
              "type": "string"
            }
          }
        }
      },
      "metadata": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": ["educational_only"]
          }
        },
        "required": ["provider", "mode"]
      }
    },
    "required": ["results", "metadata"]
  }
}
